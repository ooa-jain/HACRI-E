server {
    listen 80;
    server_name ai-survey.juooa.cloud;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name ai-survey.juooa.cloud;

    ssl_certificate     /etc/letsencrypt/live/ai-survey.juooa.cloud/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/ai-survey.juooa.cloud/privkey.pem;

    client_max_body_size 20M;

    location /static/ {
        alias /var/www/hacri_e2_integrated/app/static/;
        expires 7d;
    }

    location /generated/ {
        alias /var/www/hacri_e2_integrated/generated/;
    }

    location / {
        proxy_pass         http://127.0.0.1:8000;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 120;
    }
}
