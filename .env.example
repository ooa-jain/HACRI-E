MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=hacri_e2
SESSION_SECRET=replace-with-32-byte-random-secret
PUBLIC_BASE_URL=https://student-survey.juooa.cloud
SURVEY_ADMIN_USERNAME=survey_admin
SURVEY_ADMIN_PASSWORD=changeme
ORIENTATION_ADMIN_USERNAME=deeksha_admin
ORIENTATION_ADMIN_PASSWORD=changeme
# ── Mail provider ─────────────────────────────────────────────────────────────
# Option A — Hostinger (implicit TLS on 465):
#   SMTP_HOST=smtp.hostinger.com
#   SMTP_PORT=465
#   SMTP_USER=officeofacademics@juooa.cloud
#   SMTP_PASS=your-mailbox-password
#
# Option B — Gmail (STARTTLS on 587, uses a Google "App Password"):
#   SMTP_SERVER=smtp.gmail.com          (alias of SMTP_HOST)
#   SMTP_PORT=587
#   SMTP_EMAIL=info.ai.jain@gmail.com   (alias of SMTP_USER; also used as From)
#   SMTP_PASSWORD=your-16-char-app-password  (alias of SMTP_PASS; spaces optional)
#
# If EMAIL_FROM is omitted, the From address defaults to the SMTP login above,
# which is required for Gmail. Gmail free accounts cap ~500 emails/day.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=officeofacademics@juooa.cloud
SMTP_PASS=
EMAIL_FROM=HACRI-E <officeofacademics@juooa.cloud>
EMAIL_DRY_RUN=true
# Courtesy pause (seconds) between messages inside a bulk send. The batch reuses
# a single SMTP connection, so this can be small. Raise it if your provider
# throttles per-second sends; lower/0 to send faster.
EMAIL_BATCH_DELAY_SECONDS=0.4
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
